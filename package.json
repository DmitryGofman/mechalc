{
  "name": "mechalc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mechanical Quick Calc — fast design checks for mechanical engineers",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
